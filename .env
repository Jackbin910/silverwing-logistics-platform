# ============================================================
# 银翼智驭医流平台 - Docker Compose 环境变量配置
# 注意：此文件包含敏感信息，已加入 .gitignore，请勿提交到代码仓库
# 首次使用请复制 .env.example 为 .env 并修改对应值
# ============================================================

# ---------- 部署环境 ----------
DEPLOY_ENV=prod

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=silverwing_logistics
MYSQL_USER=silverwing
MYSQL_PASSWORD=123456

# ---------- Nacos ----------
NACOS_SERVICE_DB_NAME=nacos_config
NACOS_SERVICE_USER=nacos
NACOS_SERVICE_PASSWORD=123456
NACOS_NAMESPACE=prod
NACOS_USERNAME=nacos
NACOS_PASSWORD=123456

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- RocketMQ ----------
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT=10911

# ---------- 微服务端口 ----------
GATEWAY_PORT=8080
AUTH_PORT=8081
CORE_SERVICE_PORT=8082
DIGITAL_TWIN_PORT=8083
AI_SERVICE_PORT=8084
OPS_SERVICE_PORT=8085
INTEGRATION_PORT=8086
ADMIN_WEB_PORT=8087

# ---------- 应用版本 ----------
APP_VERSION=1.0.0
