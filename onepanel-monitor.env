# ========================================
# OnePanel 环境变量 - 监控应用
# ========================================
# 使用说明：
# 此文件用于 OnePanel「银翼-监控」应用
# 与 onepanel-monitor-compose.yml 配合使用
# ========================================

# ---------- Prometheus ----------
PROMETHEUS_PORT=9090
# 指标保留天数（在 compose 中通过 command 参数控制，此处仅文档化）
PROMETHEUS_RETENTION=7d

# ---------- Grafana ----------
GRAFANA_PORT=3000
# 首次登录管理员账号，建议修改
GRAFANA_ADMIN_USER=admin
# 首次登录管理员密码，生产环境务必修改
GRAFANA_ADMIN_PASSWORD=123456
