# ========================================
# OnePanel 环境变量 - 基础设施应用
# ========================================
# 使用说明：
# 此文件用于 OnePanel「银翼-基础设施」应用
# 与 onepanel-infra-compose.yml 配合使用
# ========================================

# ---------- 部署环境 ----------
DEPLOY_ENV=prod

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=silverwing_logistics
MYSQL_USER=silverwing
MYSQL_PASSWORD=123456

# ---------- Nacos ----------
NACOS_SERVICE_DB_NAME=nacos_config
NACOS_SERVICE_USER=nacos
NACOS_SERVICE_PASSWORD=123456

# ---------- Redis ----------
REDIS_PORT=6379


# ---------- PGVector ----------
PGVECTOR_PORT=5432
PGVECTOR_USER=silverwing
PGVECTOR_PASSWORD=123456
PGVECTOR_DATABASE=silverwing_vector

# ---------- RabbitMQ ----------
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=123456

# ---------- XXL-JOB ----------
XXLJOB_PORT=19080
XXLJOB_DB_NAME=xxl_job
XXLJOB_ACCESS_TOKEN=123456

# ---------- Nginx ----------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---------- RustFS 对象存储（S3 协议，RAG 原始文件持久化） ----------
RUSTFS_ACCESS_KEY=silverwing
RUSTFS_SECRET_KEY=123456
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
