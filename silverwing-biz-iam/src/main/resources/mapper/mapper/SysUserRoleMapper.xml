<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.silverwing.biz.iam.infrastructure.mapper.SysUserRoleMapper">

    <resultMap id="SysUserRoleResultMap" type="com.silverwing.biz.iam.domain.model.SysUserRole">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="roleId" column="role_id"/>
    </resultMap>

    <sql id="Base_Column_List">
       id, userId, roleId
    </sql>

    <!-- 根据用户ID查询角色列表 -->
    <select id="selectRolesByUserId" resultMap="SysUserRoleResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM sys_role r
        INNER JOIN sys_user_role ur ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND r.deleted = 0
          AND r.status = 1
    </select>

    <!-- 根据角色ID查询关联的用户ID列表 -->
    <select id="selectUserIdsByRoleId" resultType="java.lang.Long">
        SELECT user_id
        FROM sys_user_role
        WHERE role_id = #{roleId}
    </select>

</mapper>
