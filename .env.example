# ============================================================
# 银翼智驭医流平台 - 环境变量模板
# 使用方式：复制此文件为 .env，并根据实际环境修改值
#   cp .env.example .env
# ============================================================

# ---------- 部署环境（dev / test / prod） ----------
DEPLOY_ENV=prod

# ============================================================
# ⚠️ OnePanel Nacos 配置中心连接（必须修改）
# 微服务的所有配置都从 Nacos 读取（数据库、Redis、RocketMQ 等）
# ============================================================

# Nacos 地址（OnePanel 中 Nacos 的访问地址）
ONEPANEL_NACOS_HOST=host.docker.internal
ONEPANEL_NACOS_PORT=8848

# Nacos 认证信息（在 OnePanel 中查看或设置）
NACOS_USERNAME=nacos
NACOS_PASSWORD=<请填写 OnePanel 中 Nacos 的用户密码>

# Nacos 命名空间（默认 prod）
NACOS_NAMESPACE=prod

# ============================================================
# 📦 Docker Compose 服务配置（仅微服务端口，可自定义）
# ============================================================

# ---------- 微服务端口（默认即可，冲突时可修改） ----------
GATEWAY_PORT=8080
AUTH_PORT=8081
CORE_SERVICE_PORT=8082
DIGITAL_TWIN_PORT=8083
AI_SERVICE_PORT=8084
OPS_SERVICE_PORT=8085
INTEGRATION_PORT=8086
ADMIN_WEB_PORT=8087

# ---------- 应用版本 ----------
APP_VERSION=1.0.0
